# Copia este archivo a `.env.local` y rellena los valores.
# NUNCA commitees `.env.local` (está en .gitignore).

# --- Firebase (Project settings > General > Your apps > SDK config) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Admin ---
# El control de acceso real se hace con custom claims de Firebase (admin:true),
# verificados en el servidor (firestore.rules). Ver README / CLAUDE.md para el
# comando de asignación del claim. Ya NO se usan emails de admin en el cliente.
