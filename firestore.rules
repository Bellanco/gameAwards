/**
 * Archivo de Reglas de Firestore - Seguro para Producción
 * Copia este contenido en Firebase Console > Firestore Database > Rules
 * Luego haz clic en "Publish" para aplicar
 * 
 * Para usar estas reglas, asigna custom claims a los admins:
 * Firebase Console → Authentication → Users → Elegir usuario → Custom Claims
 * Agregar: { "admin": true }
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    /**
     * Función auxiliar: Verificar si el usuario es admin
     * Busca custom claim 'admin: true' en el token de autenticación
     * SEGURIDAD: Verificado por Firebase, imposible falsificar desde cliente
     */
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.get('admin', false) == true;
    }
    
    /**
     * Función auxiliar: Verificar si es el propietario del documento
     */
    function isOwner(userId) {
      return request.auth != null && 
             request.auth.uid == userId;
    }
    
    // ========== COLECCIÓN: ballots (votos de usuarios) ==========
    match /ballots/{userId} {
      // Lectura: Solo usuarios autenticados pueden leer
      allow read: if request.auth != null;
      
      // Escritura: SOLO el propietario del UID puede escribir/editar su voto
      // SEGURIDAD: Imposible votar como otro usuario
      allow write: if isOwner(userId) && 
                      request.auth.uid != null;
      
      // Eliminación: No permitida (soft-delete solo)
      allow delete: if false;
    }
    
    // ========== COLECCIÓN: categories (categorías - PÚBLICAS) ==========
    match /categories/{categoryId} {
      // Lectura: PÚBLICA - Cualquiera puede leer
      allow read: if true;
      
      // Escritura: Solo admins autenticados
      allow write: if isAdmin();
      
      // Eliminación: Solo admins
      allow delete: if isAdmin();
    }
    
    // ========== COLECCIÓN: winners (ganadores seleccionados por admin) ==========
    match /winners/{categoryId} {
      // Lectura: PÚBLICA
      allow read: if true;
      
      // Escritura: Solo admins
      allow write: if isAdmin();
      
      // Eliminación: Solo admins
      allow delete: if isAdmin();
    }
    
    // ========== COLECCIÓN: surveyWinners (ganadores por votación) ==========
    match /surveyWinners/{categoryId} {
      // Lectura: PÚBLICA
      allow read: if true;
      
      // Escritura: Solo admins
      allow write: if isAdmin();
      
      // Eliminación: Solo admins
      allow delete: if isAdmin();
    }
    
    // ========== COLECCIÓN: admin (configuración sensible) ==========
    match /admin/{document=**} {
      allow read, write, delete: if isAdmin();
    }
  }
}
