/**
 * Reglas de Firestore - Seguro para Producción
 * Copia este contenido en Firebase Console > Firestore Database > Rules
 * y pulsa "Publish".
 *
 * Acceso de administrador (custom claims, verificado por el servidor):
 *   Firebase Admin SDK / CLI:
 *     admin.auth().setCustomUserClaims(uid, { admin: true })
 *   El usuario debe re-loguearse (o refrescar token) para recibir el claim.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Funciones auxiliares =====
    function isAdmin() {
      return request.auth != null &&
             request.auth.token.get('admin', false) == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Validación de esquema de un voto entrante.
    function isValidBallot(userId) {
      let d = request.resource.data;
      return d.keys().hasOnly([
               'userId', 'userEmail', 'userNickname', 'userDisplayName',
               'selections', 'season', 'submittedAt', 'isActive'
             ]) &&
             d.userId == userId &&
             d.userEmail is string &&
             d.userNickname is string &&
             d.selections is map &&
             d.submittedAt is string &&
             d.isActive is bool;
    }

    // ===== ballots (votos de usuarios) =====
    match /ballots/{userId} {
      // Lectura: SOLO el propietario o un admin. (Antes: cualquier autenticado
      // podía leer email + voto de todos -> fuga de privacidad.)
      allow read: if isOwner(userId) || isAdmin();

      // Escritura: solo el propietario y solo con esquema válido.
      allow create, update: if isOwner(userId) && isValidBallot(userId);

      // Borrado: solo admin (necesario para el reinicio anual de la edición).
      allow delete: if isAdmin();
    }

    // ===== categories (categorías - lectura pública) =====
    match /categories/{categoryId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ===== config (estado de la votación - lectura pública) =====
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== results (archivo de resultados por temporada - lectura pública) =====
    match /results/{season} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ===== winners / surveyWinners (compatibilidad - lectura pública) =====
    match /winners/{categoryId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }
    match /surveyWinners/{categoryId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // ===== admin (configuración sensible) =====
    match /admin/{document=**} {
      allow read, write, delete: if isAdmin();
    }
  }
}
