/**
 * Archivo de ejemplo de Reglas de Firestore
 * Copia este contenido en Firebase Console > Firestore Database > Rules
 * Luego haz clic en "Publish" para aplicar
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Colección: ballots (votos)
    match /ballots/{userId} {
      // Lectura: Cualquier usuario autenticado puede leer (para futuras vistas de resultados)
      allow read: if request.auth != null;
      
      // Escritura: Solo el usuario dueño del UID puede escribir/editar su propio documento
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Eliminación: No permitida (evita que usuarios borren sus votos)
      allow delete: if false;
    }
    
    // Colección: admin (para datos de configuración, si es necesario)
    match /admin/{document=**} {
      // Solo administradores (requiere setup adicional con custom claims)
      allow read, write: if request.auth.token.admin == true;
    }
  }
}
