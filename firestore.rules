/**
 * Archivo de ejemplo de Reglas de Firestore
 * Copia este contenido en Firebase Console > Firestore Database > Rules
 * Luego haz clic en "Publish" para aplicar
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para verificar si es admin (por ahora cualquier usuario autenticado)
    // TODO: Mejorar con custom claims en Firebase Authentication
    function isAdmin() {
      return request.auth != null;
    }
    
    // Colección: ballots (votos de la porra)
    match /ballots/{userId} {
      // Lectura: Cualquier usuario autenticado puede leer
      allow read: if request.auth != null;
      
      // Escritura: Solo el usuario dueño del UID puede escribir/editar su propio documento
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Eliminación: No permitida
      allow delete: if false;
    }
    
    // Colección: categories (categorías de la porra - PÚBLICAS)
    match /categories/{categoryId} {
      // Lectura: PÚBLICA - Cualquiera puede leer
      allow read: if true;
      
      // Escritura: Solo admin autenticado
      allow write, delete: if isAdmin();
    }
    
    // Colección: winners (ganadores seleccionados por el admin)
    match /winners/{categoryId} {
      // Lectura: PÚBLICA
      allow read: if true;
      
      // Escritura: Solo admin
      allow write, delete: if isAdmin();
    }
    
    // Colección: surveyWinners (ganadores según resultados de votación)
    match /surveyWinners/{categoryId} {
      // Lectura: PÚBLICA
      allow read: if true;
      
      // Escritura: Solo admin
      allow write, delete: if isAdmin();
    }
    
    // Colección: admin (para datos de configuración)
    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
